# Gemini AI — required for food text/photo/barcode analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Azure Blob Storage — required when deployed to Azure Static Web Apps
# Leave empty to use local filesystem (default for local dev)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=henadzittracker
