# Gemini AI — required for food text/photo/barcode analysis + supplement AI
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic (Claude) — primary provider for the AI health summary.
# If set, the summary route uses Claude (best reasoning); Gemini is the automatic
# fallback if this key is missing or the Claude call fails. Optional.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Override the Claude model used for the summary (default: claude-opus-4-8).
# claude-sonnet-5 is the cheaper, MUCH faster near-Opus option (~15-40s vs 1-4 min) —
# strongly recommended if you see summary timeouts.
ANTHROPIC_SUMMARY_MODEL=claude-sonnet-5
# TOTAL time budget for the AI summary call (ms, default 70000) — the Claude attempt
# and the Gemini fallback share one deadline (Claude gets the budget minus ~22s
# reserved for one Gemini attempt). Keep ≤ ~80000 in production so the whole request
# finishes inside Azure Static Web Apps' ~100s gateway limit — anything longer means
# the gateway kills the request ("Request timed out") and no cache is written. Raise
# it only for local dev, where there's no gateway ceiling.
ANTHROPIC_SUMMARY_TIMEOUT_MS=70000
# Thinking effort for the summary (low/medium/high, default medium). "high" makes the
# model think substantially longer — on the production gateway budget it often causes
# the Claude attempt to hit its deadline and fall back to Gemini. Leave unset in prod.
# ANTHROPIC_SUMMARY_EFFORT=medium
# Fast mode (research preview) — runs the summary on Opus at up to 2.5× output speed,
# at premium token pricing. On by default when the summary model is Opus 4.7/4.8
# (ignored for other models); a fast-mode rate limit retries once at standard speed.
# Set to 0 to disable and always run at standard speed/pricing.
ANTHROPIC_SUMMARY_FAST=1

# Azure Blob Storage — required when deployed to Azure Static Web Apps
# Leave empty to use local filesystem (default for local dev)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=henadzittracker
